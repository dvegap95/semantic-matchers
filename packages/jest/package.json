{
  "name": "@semantic-matchers/jest",
  "version": "0.1.0",
  "description": "Jest plugin for semantic class-scoped matchers — install on expect with full TypeScript inference.",
  "sideEffects": false,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./register-types": {
      "types": "./dist/register-types.d.ts",
      "import": "./dist/register-types.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.typecheck.json",
    "test": "vitest run",
    "prepack": "yarn build"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/dvegap95/semantic-matchers.git",
    "directory": "packages/jest"
  },
  "bugs": {
    "url": "https://github.com/dvegap95/semantic-matchers/issues"
  },
  "homepage": "https://github.com/dvegap95/semantic-matchers#readme",
  "author": "dvegap95",
  "license": "MIT",
  "keywords": [
    "jest",
    "matchers",
    "expect",
    "testing",
    "typescript",
    "class-matchers",
    "custom-matchers",
    "prototype",
    "domain-driven-testing",
    "semantic-matchers",
    "jest-matchers"
  ],
  "publishConfig": {
    "access": "public"
  },
  "peerDependencies": {
    "expect": ">=29.0.0"
  },
  "dependencies": {
    "@jest/expect-utils": "^29.7.0",
    "@semantic-matchers/core": "workspace:*",
    "jest-matcher-utils": "^29.7.0"
  },
  "devDependencies": {
    "@semantic-matchers/conformance": "workspace:*",
    "@types/node": "^22.15.0",
    "expect": "^29.7.0",
    "typescript": "^5.8.3",
    "vitest": "^3.0.0"
  }
}
