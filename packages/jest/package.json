{
  "name": "@semantic-matchers/jest",
  "version": "0.1.0",
  "description": "Customize expect with class-scoped matchers for Jest. Type-specific assertion dispatch on the prototype chain — chainable with .not, .resolves, and .rejects.",
  "sideEffects": false,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./register-types": {
      "types": "./dist/register-types.d.ts",
      "import": "./dist/register-types.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.typecheck.json",
    "test": "vitest run",
    "prepack": "yarn build"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/dvegap95/semantic-matchers.git",
    "directory": "packages/jest"
  },
  "bugs": {
    "url": "https://github.com/dvegap95/semantic-matchers/issues"
  },
  "homepage": "https://github.com/dvegap95/semantic-matchers#readme",
  "author": "dvegap95",
  "license": "MIT",
  "keywords": [
    "jest",
    "jest-matchers",
    "jest-custom-matchers",
    "matchers",
    "expect",
    "expect-extend",
    "expect-customization",
    "customize-expect",
    "custom-matchers",
    "custom-assertions",
    "assertion-extensions",
    "chainable-expect",
    "expect-chaining",
    "class-matchers",
    "class-scoped-matchers",
    "class-based-matchers",
    "type-specific-matchers",
    "type-based-matchers",
    "type-aware-matchers",
    "instance-matchers",
    "object-matchers",
    "typed-matchers",
    "polymorphism",
    "polymorphic-matchers",
    "multiple-dispatch",
    "matcher-dispatch",
    "type-dispatch",
    "prototype-chain",
    "prototype-matchers",
    "inheritance-matchers",
    "instanceof",
    "domain-matchers",
    "page-object-matchers",
    "page-objects",
    "testing",
    "unit-testing",
    "typescript",
    "type-inference",
    "semantic-testing",
    "domain-driven-testing",
    "test-utilities",
    "setupFilesAfterEnv"
  ],
  "publishConfig": {
    "access": "public"
  },
  "peerDependencies": {
    "expect": ">=29.0.0"
  },
  "dependencies": {
    "@jest/expect-utils": "^29.7.0",
    "@semantic-matchers/core": "workspace:*",
    "jest-matcher-utils": "^29.7.0"
  },
  "devDependencies": {
    "@semantic-matchers/conformance": "workspace:*",
    "@types/node": "^22.15.0",
    "expect": "^29.7.0",
    "typescript": "^5.8.3",
    "vitest": "^3.0.0"
  }
}
