{
  "name": "@semantic-matchers/vitest",
  "version": "0.1.0",
  "description": "Vitest adapter — same canonical matchers as Jest, different host wiring.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./register-types": {
      "types": "./dist/register-types.d.ts",
      "import": "./dist/register-types.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "prepack": "yarn build"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/dvegap95/semantic-matchers.git",
    "directory": "packages/vitest"
  },
  "bugs": {
    "url": "https://github.com/dvegap95/semantic-matchers/issues"
  },
  "homepage": "https://github.com/dvegap95/semantic-matchers#readme",
  "author": "dvegap95",
  "license": "MIT",
  "keywords": [
    "vitest",
    "matchers",
    "expect",
    "testing",
    "typescript",
    "class-matchers"
  ],
  "publishConfig": {
    "access": "public"
  },
  "peerDependencies": {
    "vitest": ">=2.0.0"
  },
  "dependencies": {
    "@jest/expect-utils": "^29.7.0",
    "@semantic-matchers/core": "workspace:*",
    "@semantic-matchers/jest": "workspace:*",
    "jest-matcher-utils": "^29.7.0"
  },
  "devDependencies": {
    "@semantic-matchers/conformance": "workspace:*",
    "typescript": "^5.8.3",
    "vitest": "^3.0.0"
  }
}
