{
  "name": "@semantic-matchers/core",
  "version": "0.1.1",
  "description": "Framework-agnostic class-scoped matchers for expect customization. Type-specific, prototype-chain dispatch — author once, plug into Jest, Vitest, or any expect host.",
  "sideEffects": false,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./types": {
      "types": "./dist/types.d.ts",
      "import": "./dist/types.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit && tsc -p tsconfig.spec.json",
    "test": "vitest run",
    "prepack": "yarn build"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/dvegap95/semantic-matchers.git",
    "directory": "packages/core"
  },
  "bugs": {
    "url": "https://github.com/dvegap95/semantic-matchers/issues"
  },
  "homepage": "https://github.com/dvegap95/semantic-matchers#readme",
  "author": "dvegap95",
  "license": "MIT",
  "keywords": [
    "matchers",
    "expect",
    "expect-extend",
    "expect-customization",
    "custom-matchers",
    "custom-assertions",
    "class-matchers",
    "class-scoped-matchers",
    "class-based-matchers",
    "type-specific-matchers",
    "type-based-matchers",
    "type-aware-matchers",
    "instance-matchers",
    "object-matchers",
    "typed-matchers",
    "polymorphism",
    "polymorphic-matchers",
    "multiple-dispatch",
    "matcher-dispatch",
    "type-dispatch",
    "prototype-chain",
    "prototype-matchers",
    "inheritance-matchers",
    "instanceof",
    "domain-matchers",
    "page-object-matchers",
    "matcher-library",
    "framework-agnostic",
    "runner-agnostic",
    "jest",
    "vitest",
    "testing",
    "unit-testing",
    "typescript",
    "type-inference",
    "semantic-testing",
    "domain-driven-testing",
    "test-utilities",
    "matcher-pack"
  ],
  "publishConfig": {
    "access": "public"
  },
  "devDependencies": {
    "typescript": "^5.8.3",
    "vitest": "^3.0.0"
  }
}
