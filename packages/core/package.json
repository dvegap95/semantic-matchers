{
  "name": "@semantic-matchers/core",
  "version": "0.1.0",
  "description": "Framework-agnostic class-scoped matcher registry, resolution, and dispatch.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./types": {
      "types": "./dist/types.d.ts",
      "import": "./dist/types.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit && tsc -p tsconfig.spec.json",
    "test": "vitest run",
    "prepack": "yarn build"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/dvegap95/semantic-matchers.git",
    "directory": "packages/core"
  },
  "bugs": {
    "url": "https://github.com/dvegap95/semantic-matchers/issues"
  },
  "homepage": "https://github.com/dvegap95/semantic-matchers#readme",
  "author": "dvegap95",
  "license": "MIT",
  "keywords": [
    "jest",
    "vitest",
    "matchers",
    "expect",
    "testing",
    "typescript",
    "class-matchers"
  ],
  "publishConfig": {
    "access": "public"
  },
  "devDependencies": {
    "typescript": "^5.8.3",
    "vitest": "^3.0.0"
  }
}
